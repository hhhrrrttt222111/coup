{
  "name": "coup-backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "db:create": "tsx src/db/create.ts",
    "db:migrate": "tsx src/db/migrate.ts up",
    "db:migrate:down": "tsx src/db/migrate.ts down",
    "db:migrate:status": "tsx src/db/migrate.ts status",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "tsx src/db/create.ts && tsx src/db/migrate.ts up",
    "db:reset": "tsx src/db/migrate.ts down && tsx src/db/migrate.ts up && tsx src/db/seed.ts",
    "migrate": "tsx scripts/migrate.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint server.ts src/ scripts/ --max-warnings 0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "pg": "^8.13.3",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
