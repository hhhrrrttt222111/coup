PORT=3001

# Database — Supabase PostgreSQL (Transaction pooler, port 6543)
# Find this at: Supabase Dashboard > Settings > Database > Connection string > Transaction
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# For local development, use a standard PostgreSQL connection:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coup

CLIENT_URL=http://localhost:5173
NODE_ENV=development
